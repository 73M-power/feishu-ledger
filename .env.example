# Feishu custom bot webhook, same style as ai-finance-digest.
# Use this for scheduled/monthly push-only notifications.
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# Feishu app credentials for interactive group-message accounting.
# Use these only when you deploy server.py as a public webhook service.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_REPLY_ENABLED=1

LEDGER_DATA_DIR=data
PORT=8787

# Optional Feishu Bitable sync
FEISHU_DOC_SYNC_ENABLED=0
FEISHU_WIKI_TOKEN=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_VIEW_ID=
